# LLM providers
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
PRIMARY_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openrouter/free

# Real POI datası (Geoapify Places, pulsuz: 3000 kredit/gün) — boş qalsa LLM+Nominatim yolu işləyir
GEOAPIFY_API_KEY=

# Auth — production/demo üçün mütləq uzun təsadüfi dəyərlə əvəz et
JWT_SECRET=change-me-to-a-long-random-string-please

# Database (docker-compose daxilində default işləyir)
DATABASE_URL=postgresql+asyncpg://voyagent:voyagent@db:5432/voyagent

# LLM providers
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
PRIMARY_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openrouter/free

# Real POI datası (Geoapify Places, pulsuz: 3000 kredit/gün) — boş qalsa LLM+Nominatim yolu işləyir
GEOAPIFY_API_KEY=

# Auth — production/demo üçün mütləq uzun təsadüfi dəyərlə əvəz et.
# Default sirr prod-da qalsa (DEBUG_ENDPOINTS=false ikən) tətbiq start olmur.
JWT_SECRET=change-me-to-a-long-random-string-please

# CORS — icazəli frontend origin-ləri (vergüllə). Prod-da "*" istifadə etmə.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# /debug/llm və default JWT sirrinə yalnız true olduqda icazə verilir (yalnız dev)
DEBUG_ENDPOINTS=false

# Database (docker-compose daxilində default işləyir)
DATABASE_URL=postgresql+asyncpg://voyagent:voyagent@db:5432/voyagent
